<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - M&S</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .profile-container {
            max-width: 600px;
            margin: 50px auto;
            padding: 40px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: center;
        }
        .profile-avatar {
            width: 100px;
            height: 100px;
            background: #eee;
            border-radius: 50%;
            margin: 0 auto 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            color: #666;
        }
        .profile-info h1 {
            margin: 0 0 10px;
            font-size: 24px;
        }
        .profile-info p {
            color: #666;
            margin: 5px 0;
        }
        .badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            margin-top: 10px;
        }
        .badge-admin {
            background: #fef3c7;
            color: #92400e;
        }
        .badge-customer {
            background: #dcfce3;
            color: #166534;
        }
        .logout-btn {
            margin-top: 30px;
            display: inline-block;
            padding: 12px 24px;
            background: #000;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="profile-container">
        <div class="profile-avatar">
            <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div class="profile-info">
            <h1><%= user.name %></h1>
            <p><%= user.email %></p>
            <span class="badge badge-<%= user.role %>"><%= user.role %></span>
        </div>
        <a href="/logout" class="logout-btn">Logout</a>
        <br><br>
        <a href="/" style="color: #666; text-decoration: none; font-size: 14px;">← Back to Home</a>
    </div>
</body>
</html>
