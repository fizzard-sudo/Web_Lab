<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard | M&S</title>
  <link rel="stylesheet" href="/admin.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="admin-body">

  <!-- ── Sidebar ────────────────────────────────────────── -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <img src="/logo.png" alt="M&S Logo" class="sidebar-logo">
      <span class="sidebar-title">Admin Panel</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="nav-item active" id="nav-dashboard">
        <span class="nav-icon"></span>
        <span>Dashboard</span>
      </a>
      <a href="/admin/add" class="nav-item" id="nav-add-product">
        <span class="nav-icon"></span>
        <span>Add Product</span>
      </a>
      <a href="/products" class="nav-item" id="nav-storefront">
        <span class="nav-icon"></span>
        <span>Storefront</span>
      </a>
      <a href="/" class="nav-item" id="nav-homepage">
        <span class="nav-icon"></span>
        <span>Homepage</span>
      </a>
    </nav>
    <div class="sidebar-footer">
      <p>&copy; 2026 M&S Admin</p>
    </div>
  </aside>

  <!-- ── Main Content ───────────────────────────────────── -->
  <main class="admin-main">

    <!-- Top Bar -->
    <header class="admin-topbar">
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">☰</button>
      <h1 class="topbar-title">Product Dashboard</h1>
      <a href="/admin/add" class="btn btn-primary" id="topbar-add-btn">+ Add Product</a>
    </header>

    <!-- Alerts -->
    <% if (success) { %>
      <div class="alert alert-success" id="alert-success">
        <span class="alert-icon"></span>
        <span>
          <%= success %>
        </span>
        <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
      </div>
      <% } %>
        <% if (error) { %>
          <div class="alert alert-error" id="alert-error">
            <span class="alert-icon"></span>
            <span>
              <%= error %>
            </span>
            <button class="alert-close" onclick="this.parentElement.remove()">&times;</button>
          </div>
          <% } %>

            <!-- Stats Cards -->
            <section class="stats-grid">
              <div class="stat-card" id="stat-total-products">

                <div class="stat-info">
                  <p class="stat-label">Total Products</p>
                  <h2 class="stat-value">
                    <%= products.length %>
                  </h2>
                </div>
              </div>
              <div class="stat-card" id="stat-categories">

                <div class="stat-info">
                  <p class="stat-label">Categories</p>
                  <h2 class="stat-value">
                    <%= categories.length %>
                  </h2>
                </div>
              </div>
              <div class="stat-card" id="stat-total-stock">

                <div class="stat-info">
                  <p class="stat-label">Total Stock</p>
                  <h2 class="stat-value">
                    <%= totalStock.toLocaleString() %>
                  </h2>
                </div>
              </div>
              <div class="stat-card" id="stat-inventory-value">

                <div class="stat-info">
                  <p class="stat-label">Inventory Value</p>
                  <h2 class="stat-value">$<%= totalValue.toLocaleString(undefined, {minimumFractionDigits: 2,
                      maximumFractionDigits: 2}) %>
                  </h2>
                </div>
              </div>
            </section>

            <!-- Search & Filter Bar -->
            <section class="table-toolbar">
              <div class="search-wrap">
                <input type="text" id="productSearch" class="search-input"
                  placeholder="Search products by name, category...">
              </div>
            </section>

            <!-- Products Table -->
            <section class="table-container">
              <table class="admin-table" id="productsTable">
                <thead>
                  <tr>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Rating</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody id="productsTableBody">
                  <% if (products.length===0) { %>
                    <tr>
                      <td colspan="7" class="empty-row">
                        <div class="empty-state-admin">
                          <p>No products found.</p>
                          <a href="/admin/add" class="btn btn-primary">Add Your First Product</a>
                        </div>
                      </td>
                    </tr>
                    <% } %>

                      <% products.forEach((product)=> { %>
                        <tr class="product-row" data-name="<%= product.name.toLowerCase() %>"
                          data-category="<%= product.category.toLowerCase() %>">
                          <td>
                            <div class="table-image-wrap">
                              <img src="<%= product.image || '/img6.avif' %>" alt="<%= product.name %>">
                            </div>
                          </td>
                          <td>
                            <div class="product-info-cell">
                              <strong>
                                <%= product.name %>
                              </strong>
                              <% if (product.description) { %>
                                <span class="product-desc-preview">
                                  <%= product.description.substring(0, 50) %>
                                    <%= product.description.length> 50 ? '...' : '' %>
                                </span>
                                <% } %>
                            </div>
                          </td>
                          <td><span class="category-badge">
                              <%= product.category %>
                            </span></td>
                          <td class="price-cell">$<%= product.price.toFixed(2) %>
                          </td>
                          <td>
                            <span
                              class="stock-indicator <%= product.stock > 10 ? 'stock-good' : product.stock > 0 ? 'stock-low' : 'stock-out' %>">
                              <%= product.stock %>
                            </span>
                          </td>
                          <td>
                            <div class="rating-stars">
                              ★ <%= product.rating.toFixed(1) %>
                            </div>
                          </td>
                          <td>
                            <div class="action-buttons">
                              <a href="/admin/edit/<%= product._id %>" class="btn btn-edit" id="edit-<%= product._id %>"
                                title="Edit product">
                                ✏️ Edit
                              </a>
                              <button type="button" class="btn btn-delete" id="delete-btn-<%= product._id %>"
                                title="Delete product"
                                onclick="confirmDelete('<%= product._id %>', '<%= product.name.replace(/'/g, " \\'")
                                %>')">
                                Delete
                              </button>
                            </div>
                          </td>
                        </tr>
                        <% }) %>
                </tbody>
              </table>
            </section>
  </main>

  <!-- ── Delete Confirmation Modal ──────────────────────── -->
  <div class="modal-overlay" id="deleteModal">
    <div class="modal-content">
      <div class="modal-icon"></div>
      <h2>Delete Product</h2>
      <p>Are you sure you want to delete <strong id="deleteProductName"></strong>?</p>
      <p class="modal-warning">This action cannot be undone.</p>
      <div class="modal-actions">
        <button class="btn btn-cancel" id="cancelDelete" onclick="closeDeleteModal()">Cancel</button>
        <form id="deleteForm" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-confirm-delete" id="confirmDeleteBtn">Yes, Delete</button>
        </form>
      </div>
    </div>
  </div>

  <script>
    // ── Sidebar toggle ────────────────────────────────────
    const sidebar = document.getElementById('sidebar');
    const toggleBtn = document.getElementById('sidebarToggle');

    toggleBtn.addEventListener('click', () => {
      sidebar.classList.toggle('collapsed');
    });

    // ── Live search ───────────────────────────────────────
    const searchInput = document.getElementById('productSearch');
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.toLowerCase();
      const rows = document.querySelectorAll('.product-row');

      rows.forEach(row => {
        const name = row.getAttribute('data-name');
        const category = row.getAttribute('data-category');
        const matches = name.includes(query) || category.includes(query);
        row.style.display = matches ? '' : 'none';
      });
    });

    // ── Delete confirmation modal ─────────────────────────
    function confirmDelete(id, name) {
      const modal = document.getElementById('deleteModal');
      const form = document.getElementById('deleteForm');
      const nameEl = document.getElementById('deleteProductName');

      nameEl.textContent = name;
      form.action = '/admin/delete/' + id;
      modal.classList.add('visible');
    }

    function closeDeleteModal() {
      document.getElementById('deleteModal').classList.remove('visible');
    }

    // Close modal on overlay click
    document.getElementById('deleteModal').addEventListener('click', (e) => {
      if (e.target === e.currentTarget) closeDeleteModal();
    });

    // Close modal on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDeleteModal();
    });

    // Auto-dismiss success alerts
    const successAlert = document.getElementById('alert-success');
    if (successAlert) {
      setTimeout(() => {
        successAlert.style.opacity = '0';
        successAlert.style.transform = 'translateY(-10px)';
        setTimeout(() => successAlert.remove(), 400);
      }, 4000);
    }
  </script>
</body>

</html>